# CeloPulse Environment Variables

# Contract Address (Deploy CeloPulse.sol on Remix and add address here)
NEXT_PUBLIC_CELOPULSE_CONTRACT=0x...

# WalletConnect Project ID (replace placeholder before running the app)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# App Metadata
NEXT_PUBLIC_APP_NAME=CeloPulse
NEXT_PUBLIC_APP_DESCRIPTION=Real-time blockchain activity tracker with auto-rewards
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Network (use 42220 for Celo mainnet, 11142220 for Celo Sepolia testnet)
NEXT_PUBLIC_CHAIN_ID=42220

# Optional MiniPay fee currency.
# Leave blank to use USDm on Celo mainnet. Set an address explicitly for Celo Sepolia.
NEXT_PUBLIC_MINIPAY_FEE_CURRENCY=
